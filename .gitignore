# ============================================================
#   GPLAST ERP TICKET SYSTEM — .gitignore
#   Django + MySQL | Production: Dell On-Premise Server
# ============================================================


# ------------------------------------------------------------
# ENVIRONMENT & SECRETS — NEVER COMMIT THESE
# ------------------------------------------------------------
.env
.env.*
!.env.example
*.env
secrets.json
local_settings.py


# ------------------------------------------------------------
# PYTHON
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.pyz
*.pyc

# Python packaging
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
wheels/
pip-wheel-metadata/
share/python-wheels/
MANIFEST


# ------------------------------------------------------------
# VIRTUAL ENVIRONMENT
# ------------------------------------------------------------
venv/
env/
ENV/
.venv/
.ENV/
virtualenv/
.virtualenv/
Pipfile.lock


# ------------------------------------------------------------
# DJANGO SPECIFIC
# ------------------------------------------------------------

# Django collected static files (generated by collectstatic)
staticfiles/
static_root/
collected_static/

# Django media uploads (user-uploaded files — store on server, not in git)
media/
uploads/
attachments/

# Django local database (SQLite — dev only, MySQL used in production)
db.sqlite3
db.sqlite3-journal
*.sqlite3

# Django migrations — TEAM DECISION:
# Option A: Track migrations (recommended for teams)
# Option B: Ignore migrations (uncomment below if needed)
# */migrations/*.py
# !*/migrations/__init__.py

# Django cache
django_cache/
.cache/

# Django test coverage
.coverage
htmlcov/
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

# Celery (if added later)
celerybeat-schedule
celerybeat.pid


# ------------------------------------------------------------
# DATABASE — NEVER COMMIT DB FILES OR DUMPS WITH REAL DATA
# ------------------------------------------------------------
*.sql
*.dump
*.db
*.sqlite
*.mdb
database_backup/
db_backup/
db_dumps/
mysql_dumps/


# ------------------------------------------------------------
# LOGS
# ------------------------------------------------------------
*.log
*.log.*
logs/
log/
django.log
error.log
access.log
debug.log
gunicorn.log
gunicorn-access.log
gunicorn-error.log


# ------------------------------------------------------------
# UPLOADED FILES & MEDIA
# ------------------------------------------------------------
# Ticket attachments uploaded by users
media/
uploads/
attachments/
*.pdf
*.doc
*.docx
*.xls
*.xlsx


# ------------------------------------------------------------
# EXPORTED REPORTS
# ------------------------------------------------------------
reports/
exports/
report_exports/
*.csv


# ------------------------------------------------------------
# OPERATING SYSTEM FILES
# ------------------------------------------------------------

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk
*.cab
*.msi
*.msix
*.msm
*.msp

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride
Icon?
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*


# ------------------------------------------------------------
# IDE AND EDITOR FILES
# ------------------------------------------------------------

# VS Code
.vscode/
*.code-workspace
.history/

# PyCharm / JetBrains
.idea/
*.iml
*.iws
*.ipr
.idea_modules/
out/
.fleet/

