*.swo
*.swn
Session.vim
.netrwhist

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp
.\#*

# Spyder
.spyderproject.cfg
.spyproject

# Rope
.ropeproject

# Eclipse
.project
.pydevproject
.settings/


# ------------------------------------------------------------
# NODE / FRONTEND (if npm/webpack ever added)
# ------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn/
.pnp.*
package-lock.json
yarn.lock
dist/
.parcel-cache/


# ------------------------------------------------------------
# TESTING & COVERAGE
# ------------------------------------------------------------
.tox/
.nox/
.coverage
.coverage.*
coverage.xml
*.cover
*.py,cover
htmlcov/
.pytest_cache/
nosetests.xml
test-results/
test_output/


# ------------------------------------------------------------
# DEPLOYMENT & SERVER
# ------------------------------------------------------------

# Gunicorn / uWSGI
gunicorn.pid
uwsgi.pid
*.pid

# Nginx (if config stored locally)
nginx_local.conf

# SSL Certificates — never commit these
*.pem
*.key
*.crt
*.cer
*.p12
*.pfx
ssl/
certs/

# Docker (if added later)
.dockerignore
docker-compose.override.yml

# Compiled files
*.mo
*.pot


# ------------------------------------------------------------
# TEMPORARY FILES
# ------------------------------------------------------------
tmp/
temp/
*.tmp
*.temp
*.bak
*.backup
*.orig
*.rej
*.patch


# ------------------------------------------------------------
# REQUIREMENTS BACKUPS
# ------------------------------------------------------------
requirements_backup.txt
requirements_old.txt
requirements_dev.txt


# ============================================================
# FILES THAT MUST BE COMMITTED (DO NOT ADD THESE ABOVE)
# ============================================================
# .env.example          ← Always commit the example env file
# requirements.txt      ← Always commit dependencies
# manage.py             ← Always commit
# */migrations/         ← Commit migrations (team consistency)
# static/               ← Commit your own CSS/JS source files
# templates/            ← Commit all templates
# ============================================================